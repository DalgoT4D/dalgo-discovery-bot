# LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                       # used only for embeddings

# Database (local Postgres + pgvector via Docker — see docker-compose.yml)
DATABASE_URL=postgres://dalgo:dalgo_dev@localhost:5436/dalgo_discovery
# Pooling / deploy (AWS RDS). Locally leave SSL unset.
DB_POOL_MAX=10                        # connections per container; total = replicas × this
DB_CONNECT_TIMEOUT_MS=10000
DATABASE_SSL=                         # set "true" on RDS
DATABASE_SSL_STRICT=                  # "true" + bundle RDS CA for full cert verification

# External services
TAVILY_API_KEY=
RESEND_API_KEY=                       # OPTIONAL — only for weekly KB audit email
SLACK_HOT_LEAD_WEBHOOK_URL=           # OPTIONAL — hot-lead Slack notifications

# Admin auth — pick one or both:
#   A) Username + password (simplest for local/dev)
#   B) Google SSO (production)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                      # REQUIRED if using admin. Generate with: openssl rand -base64 32

# A) Username/password — generate hash with:  npm run admin:hash <your-password>
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=

# B) Google SSO (leave empty to skip)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_ALLOWED_EMAIL_DOMAINS=dalgo.org,tech4dev.org

# Rate limiting (per IP, fixed window)
RATE_LIMIT_MAX_MSG=40
RATE_LIMIT_WINDOW_MINUTES=30

# Abuse protection (per IP) — soft-block after N consecutive junk/off-topic turns
ABUSE_STRIKE_THRESHOLD=5
ABUSE_BLOCK_MINUTES=30
MAX_MESSAGE_CHARS=4000

# Cron
CRON_SECRET=
ADMIN_DIGEST_RECIPIENTS=

# Telemetry
LOG_LEVEL=info
NEXT_PUBLIC_PLATFORM_URL=http://localhost:3001
NEXT_PUBLIC_GUEST_EMAIL=guest_user@dalgo.org
NEXT_PUBLIC_GUEST_PASSWORD=password
